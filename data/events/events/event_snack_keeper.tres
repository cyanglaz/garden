[resource]
script = ExtResource("1_qgoj6")
option_ids = Array[String](["pollen_puff", "crystallized_nectar", "leave"])
id = "snack_keeper"
description = "A stout bee in a stained leaf-satchel hovers over a bark table. She’s surrounded by pollen puffs and crystallized nectar, currently mid-chew on a piece of sticky honeycomb.

She eyes you with deep suspicion, hugging a jar of jelly to her chest. \"Want a bite? Fine,\" she hums with a lazy, raspy tune. \"But I'm only parting with one—my stomach can't handle any more heartbreak. Leave your coin and be gone. \""
